    return result


# This function chooses the right strategy for one leaf block.
def rewrite_one_block(
    client: AzureOpenAI,
    deployment_name: str,
    block_html: str,
    block_tag_name: str,
    rules: Sequence[str],
    max_attempts: int = 3,
) -> Dict[str, object]:
    if block_tag_name in CELL_BLOCK_TAGS:
        return rewrite_table_cell_block(
            client=client,
            deployment_name=deployment_name,
            block_html=block_html,
            rules=rules,
            max_attempts=max_attempts,
        )

    return rewrite_raw_html_block(
        client=client,
        deployment_name=deployment_name,
        block_html=block_html,
        rules=rules,
        max_attempts=max_attempts,
    )

