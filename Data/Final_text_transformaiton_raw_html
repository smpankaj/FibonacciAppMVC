) -> str:
    prompt = ""
    prompt = prompt + "Apply the following rules to this table cell.\n\n"
    prompt = prompt + "Rules:\n"
    prompt = prompt + format_rules(rules)
    prompt = prompt + "\n\n"
    prompt = prompt + "HTML cell:\n"
    prompt = prompt + prepared_html

    if repair_errors:
        prompt = prompt + "\n\n"
        prompt = prompt + "Your previous answer failed validation for these reasons:\n"

        for error in repair_errors:
            prompt = prompt + "- " + error + "\n"

        prompt = prompt + "\nRepair the HTML while keeping the same cell tag and the same markers."

    return prompt


# This function sends one prepared block to Azure OpenAI and returns the model text.
def call_model(
    client: AzureOpenAI,
    deployment_name: str,
    system_prompt: str,
    user_prompt: str,
) -> str:
    completion = client.chat.completions.create(
        model=deployment_name,
        temperature=0,
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ],
    )

    content = completion.choices[0].message.content

    if content is None:
        return ""

    return strip_code_fences(content)

