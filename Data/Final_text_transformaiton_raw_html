""".strip()


# This function formats the style rules as a numbered list for the prompt.
def format_rules(rules: Sequence[str]) -> str:
    lines = []

    rule_number = 1
    for rule in rules:
        lines.append(str(rule_number) + ". " + rule)
        rule_number = rule_number + 1

    return "\n".join(lines)


# This function removes markdown code fences if the model adds them anyway.
def strip_code_fences(text: str) -> str:
    if not text:
        return text

    cleaned_text = text.strip()

    fence_match = re.match(
        r"^```(?:html)?\s*(.*?)\s*```$",
        cleaned_text,
        flags=re.DOTALL | re.IGNORECASE,
    )

    if fence_match:
        return fence_match.group(1).strip()

    return cleaned_text


# This function builds the user prompt for raw HTML blocks.
def build_raw_html_user_prompt(
    prepared_html: str,
    rules: Sequence[str],
    repair_errors: Optional[Sequence[str]] = None,
) -> str:
    prompt = ""
    prompt = prompt + "Apply the following rules to this HTML block.\n\n"
    prompt = prompt + "Rules:\n"
    prompt = prompt + format_rules(rules)
    prompt = prompt + "\n\n"
    prompt = prompt + "HTML block:\n"
    prompt = prompt + prepared_html

    if repair_errors:
        prompt = prompt + "\n\n"
        prompt = prompt + "Your previous answer failed validation for these reasons:\n"

        for error in repair_errors:
            prompt = prompt + "- " + error + "\n"

        prompt = prompt + "\nRepair the HTML while keeping the same structure and markers."

    return prompt


# This function builds the user prompt for table cells that use inline markers.
def build_cell_user_prompt(
    prepared_html: str,
