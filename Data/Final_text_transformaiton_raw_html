# This function rewrites one raw HTML block.
# Before the model sees the block, protected bold tags are replaced with visible KEEP markers.
# After the model returns HTML, the original protected tags are restored and validated.
def rewrite_raw_html_block(
    client: AzureOpenAI,
    deployment_name: str,
    block_html: str,
    rules: Sequence[str],
    max_attempts: int = 3,
) -> Dict[str, object]:
    prepared_html, keep_map = replace_protected_tags_with_keep_markers(block_html)

    result = {}
    result["strategy"] = "raw_html"
    result["original_html"] = block_html
    result["prepared_html"] = prepared_html
    result["rewritten_html"] = block_html
    result["restored_html"] = block_html
    result["attempts"] = 0
    result["is_valid"] = False
    result["errors"] = []

    repair_errors = None

    for attempt_number in range(1, max_attempts + 1):
        user_prompt = build_raw_html_user_prompt(prepared_html, rules, repair_errors)
        candidate_html = call_model(
            client=client,
            deployment_name=deployment_name,
            system_prompt=RAW_HTML_SYSTEM_PROMPT,
            user_prompt=user_prompt,
        )

        marker_errors = validate_keep_markers(candidate_html, keep_map)

        if len(marker_errors) > 0:
            result["rewritten_html"] = candidate_html
            result["restored_html"] = candidate_html
            result["attempts"] = attempt_number
            result["is_valid"] = False
            result["errors"] = marker_errors
            repair_errors = marker_errors
            continue

        restored_html = restore_keep_markers(candidate_html, keep_map)
        validation = validate_restored_block(block_html, restored_html)

        result["rewritten_html"] = candidate_html
        result["restored_html"] = restored_html
        result["attempts"] = attempt_number
        result["is_valid"] = validation["is_valid"]
        result["errors"] = validation["errors"]

        if validation["is_valid"]:
            return result

        repair_errors = validation["errors"]

    return result


