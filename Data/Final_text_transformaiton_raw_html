# COMMAND ----------
RAW_HTML_BLOCK_TAGS = set([
    "p",
    "li",
    "caption",
    "h1",
    "h2",
    "h3",
    "h4",
    "h5",
    "h6",
])

CELL_BLOCK_TAGS = set([
    "td",
    "th",
])

REWRITE_BLOCK_TAGS = set()
for tag_name in RAW_HTML_BLOCK_TAGS:
    REWRITE_BLOCK_TAGS.add(tag_name)
for tag_name in CELL_BLOCK_TAGS:
    REWRITE_BLOCK_TAGS.add(tag_name)

PROTECTED_TAGS = set([
    "b",
    "strong",
])

# COMMAND ----------
# MAGIC %md
# MAGIC ## Parsing helpers
# MAGIC
# MAGIC These helpers parse the HTML fragment and find the smallest block elements that we want to
# MAGIC rewrite safely.

# COMMAND ----------

# This function parses an HTML fragment by wrapping it in a temporary <root> element.
# Wrapping the fragment makes it easier to handle partial HTML safely.
def parse_fragment(fragment: str) -> Tuple[BeautifulSoup, Tag]:
    wrapped_html = "<root>" + fragment + "</root>"
    soup = BeautifulSoup(wrapped_html, "lxml")
    root = soup.find("root")

    if root is None:
        raise ValueError("Could not parse HTML fragment.")

    return soup, root


# This function converts everything inside our temporary <root> wrapper back to a plain string.
# We use it at the very end to return the transformed HTML fragment.
def fragment_to_string(root: Tag) -> str:
    output_parts = []

    for child in root.contents:
        output_parts.append(str(child))

    return "".join(output_parts)


# This function returns the "important" children of a tag.
# It ignores comments and whitespace-only text nodes.
def significant_children(node: Tag) -> List[object]:
    children = []

    for child in node.contents:
        if isinstance(child, Comment):
            continue

        if isinstance(child, NavigableString):
            child_text = str(child)
            if child_text.strip() == "":
                continue
            children.append(child)
            continue

        if isinstance(child, Tag):
            children.append(child)

    return children


# This function checks whether a tag contains another rewriteable block inside it.
# If it does, then this tag is not a leaf block.
def contains_descendant_rewrite_block(tag: Tag) -> bool:
    for descendant in tag.find_all(REWRITE_BLOCK_TAGS):
        if descendant is not tag:
            return True
    return False


# This function finds the smallest rewriteable blocks in the document.
# We call them "leaf blocks" because they are the lowest safe blocks in the HTML tree.
def find_leaf_rewrite_targets(root: Tag) -> List[Tag]:
    targets = []

    for tag in root.find_all(REWRITE_BLOCK_TAGS):
        if contains_descendant_rewrite_block(tag):
            continue
        targets.append(tag)

    return targets


# This function makes sure that a fragment contains exactly one real root tag.
# We use it for validation after the model returns a rewritten block.
def extract_single_tag(fragment: str) -> Tag:
    soup, root = parse_fragment(fragment)
    important_children = significant_children(root)

    tag_children = []
    non_tag_children = []

    for child in important_children:
        if isinstance(child, Tag):
            tag_children.append(child)
        else:
            non_tag_children.append(child)

    if len(non_tag_children) > 0:
        raise ValueError("Rewritten block contains text outside the root tag.")

    if len(tag_children) != 1:
        raise ValueError("Expected exactly one root tag, but found " + str(len(tag_children)) + ".")

    return tag_children[0]

# COMMAND ----------
# MAGIC %md
# MAGIC ## HTML comparison helpers
# MAGIC
# MAGIC These helpers create normalized signatures so we can compare the original HTML block and the
# MAGIC rebuilt HTML block after the model rewrite.

# COMMAND ----------

# This function normalizes one attribute value.
# BeautifulSoup may represent some attributes as lists, so we convert them to strings in a
# consistent way before comparing them.
def normalize_attr_value(value) -> object:
    if isinstance(value, list):
        normalized_parts = []

        for item in value:
            normalized_parts.append(str(item))

        return tuple(normalized_parts)

    return str(value)


# This function normalizes all attributes for one tag.
# The output is sorted so that attribute order differences do not create false validation errors.
def normalize_attrs(tag: Tag) -> Tuple[Tuple[str, object], ...]:
    pairs = []

    for key, value in tag.attrs.items():
        normalized_value = normalize_attr_value(value)
        pairs.append((key, normalized_value))

    pairs.sort()
    return tuple(pairs)


# This function builds a structural signature for a tag and all important descendants.
# The signature helps us compare structure without being distracted by normal text changes.
def structure_signature(node: Tag) -> Tuple[object, ...]:
    signature_parts = []

    for child in significant_children(node):
        if isinstance(child, NavigableString):
            signature_parts.append(("TEXT",))
        elif isinstance(child, Tag):
            child_signature = structure_signature(child)
            child_record = (
                "TAG",
                child.name,
                normalize_attrs(child),
                child_signature,
            )
            signature_parts.append(child_record)

    return tuple(signature_parts)

# COMMAND ----------
# MAGIC %md
# MAGIC ## Marker helpers
# MAGIC
# MAGIC The notebook uses two kinds of markers:
# MAGIC
# MAGIC 1. **KEEP markers**
# MAGIC    - used for text that must not be changed, such as text inside `<b>` and `<strong>`
# MAGIC 2. **INLINE markers**
# MAGIC    - used inside table cells to protect inline tags such as `<a>` and `<span>` while still
# MAGIC      letting the model see and rewrite the text inside those tags

# COMMAND ----------

# This function creates a KEEP start marker string such as:
# MAGIC # ⟦KEEP_1_START⟧
def build_keep_start_marker(marker_number: int) -> str:
    return "⟦KEEP_" + str(marker_number) + "_START⟧"


# This function creates a KEEP end marker string such as:
# MAGIC # ⟦KEEP_1_END⟧
def build_keep_end_marker(marker_number: int) -> str:
    return "⟦KEEP_" + str(marker_number) + "_END⟧"


# This function creates an INLINE start marker string such as:
# MAGIC # ⟦TAG_1_START⟧
def build_inline_start_marker(marker_number: int) -> str:
    return "⟦TAG_" + str(marker_number) + "_START⟧"


# This function creates an INLINE end marker string such as:
# MAGIC # ⟦TAG_" + str(marker_number) + "_END⟧
def build_inline_end_marker(marker_number: int) -> str:
    return "⟦TAG_" + str(marker_number) + "_END⟧"


# This function creates a single marker for empty tags such as <br/>.
def build_empty_marker(marker_number: int) -> str:
    return "⟦EMPTY_" + str(marker_number) + "⟧"


# This function builds the opening HTML for a tag.
# We reconstruct the opening tag from the original tag name and original attributes.
def build_opening_tag_html(tag: Tag) -> str:
    pieces = []
    pieces.append("<")
    pieces.append(tag.name)

    for attr_name, attr_value in tag.attrs.items():
        pieces.append(" ")
        pieces.append(attr_name)
        pieces.append('="')

        if isinstance(attr_value, list):
            value_parts = []
            for item in attr_value:
                value_parts.append(str(item))
            pieces.append(" ".join(value_parts))
        else:
            pieces.append(str(attr_value))

        pieces.append('"')

    pieces.append(">")
    return "".join(pieces)


# This function builds a closing HTML tag such as </a>.
def build_closing_tag_html(tag: Tag) -> str:
    return "</" + tag.name + ">"


# This function returns the plain visible text inside a protected tag.
# We use this so the model can still see the protected words for context.
def visible_text_for_protected_tag(tag: Tag) -> str:
    return tag.get_text()


# This function scans a block and replaces every protected bold tag with visible KEEP markers.
# The model still sees the protected words, but our code later restores the original bold tag.
def replace_protected_tags_with_keep_markers(block_html: str) -> Tuple[str, Dict[str, Dict[str, str]]]:
    original_tag = extract_single_tag(block_html)

    working_tag = BeautifulSoup(str(original_tag), "lxml").find(original_tag.name)
    keep_map = {}
    marker_number = 1

    # We collect the protected descendants first because replacing nodes while iterating
    # directly over descendants can be confusing and error-prone for beginners.
    protected_nodes = []

    for descendant in working_tag.descendants:
        if isinstance(descendant, Tag):
            if descendant.name in PROTECTED_TAGS:
                protected_nodes.append(descendant)

    for protected_tag in protected_nodes:
        start_marker = build_keep_start_marker(marker_number)
        end_marker = build_keep_end_marker(marker_number)
        visible_text = visible_text_for_protected_tag(protected_tag)
        full_marker_text = start_marker + visible_text + end_marker

        marker_info = {}
        marker_info["start_marker"] = start_marker
        marker_info["end_marker"] = end_marker
        marker_info["full_marker_text"] = full_marker_text
        marker_info["original_html"] = str(protected_tag)
        marker_info["visible_text"] = visible_text

        keep_map[str(marker_number)] = marker_info

        protected_tag.replace_with(NavigableString(full_marker_text))
        marker_number = marker_number + 1

    markerized_html = str(working_tag)
    return markerized_html, keep_map


# This function checks whether every protected KEEP marker survived exactly as expected.
# If the model changed, removed, or duplicated a marker, this function reports an error.
def validate_keep_markers(candidate_html: str, keep_map: Dict[str, Dict[str, str]]) -> List[str]:
    errors = []

    for marker_number, marker_info in keep_map.items():
        marker_text = marker_info["full_marker_text"]
        count = candidate_html.count(marker_text)

        if count != 1:
            error_message = (
                "Protected marker " + marker_number + " should appear exactly once, "
                "but it appeared " + str(count) + " times."
            )
            errors.append(error_message)

    return errors


# This function restores every KEEP marker back to its original protected HTML tag.
def restore_keep_markers(candidate_html: str, keep_map: Dict[str, Dict[str, str]]) -> str:
    restored_html = candidate_html

    for marker_number, marker_info in keep_map.items():
        marker_text = marker_info["full_marker_text"]
        original_html = marker_info["original_html"]
        restored_html = restored_html.replace(marker_text, original_html)

    return restored_html


# This helper walks through a node recursively and converts the inside of a table cell into
# markerized text. Protected tags become KEEP markers. Editable inline tags become TAG markers.
def node_to_marker_text_for_cell(
    node,
    inline_map: Dict[str, Dict[str, str]],
    keep_map: Dict[str, Dict[str, str]],
    marker_counters: Dict[str, int],
) -> str:
    # Case 1: normal text node
    if isinstance(node, NavigableString):
        return str(node)

    # Case 2: only Tag objects below this point
    if not isinstance(node, Tag):
        return ""

    # Protected bold tags become KEEP markers.
    if node.name in PROTECTED_TAGS:
        keep_number = marker_counters["keep"]
        marker_counters["keep"] = marker_counters["keep"] + 1

        start_marker = build_keep_start_marker(keep_number)
        end_marker = build_keep_end_marker(keep_number)
        visible_text = visible_text_for_protected_tag(node)
        full_marker_text = start_marker + visible_text + end_marker

        marker_info = {}
        marker_info["start_marker"] = start_marker
        marker_info["end_marker"] = end_marker
        marker_info["full_marker_text"] = full_marker_text
        marker_info["original_html"] = str(node)
        marker_info["visible_text"] = visible_text

        keep_map[str(keep_number)] = marker_info
        return full_marker_text

    # Empty tags such as <br/> become one simple EMPTY marker.
    if len(node.contents) == 0:
        empty_number = marker_counters["empty"]
        marker_counters["empty"] = marker_counters["empty"] + 1

        empty_marker = build_empty_marker(empty_number)

        marker_info = {}
        marker_info["empty_marker"] = empty_marker
        marker_info["original_html"] = str(node)

        inline_map["EMPTY_" + str(empty_number)] = marker_info
        return empty_marker

    # Other editable inline tags become paired start/end markers.
    inline_number = marker_counters["inline"]
    marker_counters["inline"] = marker_counters["inline"] + 1

    start_marker = build_inline_start_marker(inline_number)
    end_marker = build_inline_end_marker(inline_number)

    marker_info = {}
    marker_info["start_marker"] = start_marker
    marker_info["end_marker"] = end_marker
    marker_info["opening_html"] = build_opening_tag_html(node)
    marker_info["closing_html"] = build_closing_tag_html(node)
    marker_info["tag_name"] = node.name

    inline_map[str(inline_number)] = marker_info

    child_text_parts = []

    for child in node.contents:
        child_text = node_to_marker_text_for_cell(child, inline_map, keep_map, marker_counters)
        child_text_parts.append(child_text)

    inner_text = "".join(child_text_parts)
    return start_marker + inner_text + end_marker


# This function converts the inside of a table cell into markerized text.
# The outer <td> or <th> tag stays as HTML, but the inside becomes marker-friendly text.
def prepare_cell_html_with_markers(cell_html: str) -> Tuple[str, Dict[str, Dict[str, str]], Dict[str, Dict[str, str]]]:
    original_tag = extract_single_tag(cell_html)

    if original_tag.name not in CELL_BLOCK_TAGS:
        raise ValueError("Cell marker preparation expects a <td> or <th> block.")

    inline_map = {}
    keep_map = {}

    marker_counters = {}
    marker_counters["inline"] = 1
    marker_counters["keep"] = 1
    marker_counters["empty"] = 1

    inner_text_parts = []

    for child in original_tag.contents:
        child_text = node_to_marker_text_for_cell(child, inline_map, keep_map, marker_counters)
        inner_text_parts.append(child_text)

    inner_marker_text = "".join(inner_text_parts)

    opening_html = build_opening_tag_html(original_tag)
    closing_html = build_closing_tag_html(original_tag)
    prepared_html = opening_html + inner_marker_text + closing_html

    return prepared_html, inline_map, keep_map


# This function checks that each inline marker appears exactly once in the model output.
def validate_inline_marker_counts(candidate_html: str, inline_map: Dict[str, Dict[str, str]]) -> List[str]:
    errors = []

    for marker_number, marker_info in inline_map.items():
        if marker_number.startswith("EMPTY_"):
            empty_marker = marker_info["empty_marker"]
            empty_count = candidate_html.count(empty_marker)

            if empty_count != 1:
                error_message = (
                    "Empty marker " + empty_marker + " should appear exactly once, "
                    "but it appeared " + str(empty_count) + " times."
                )
                errors.append(error_message)

            continue

        start_marker = marker_info["start_marker"]
        end_marker = marker_info["end_marker"]

        start_count = candidate_html.count(start_marker)
        end_count = candidate_html.count(end_marker)

        if start_count != 1:
            error_message = (
                "Start marker " + start_marker + " should appear exactly once, "
                "but it appeared " + str(start_count) + " times."
            )
            errors.append(error_message)

        if end_count != 1:
            error_message = (
                "End marker " + end_marker + " should appear exactly once, "
                "but it appeared " + str(end_count) + " times."
            )
            errors.append(error_message)

    return errors


# This function checks whether the inline start and end markers are properly balanced.
# We scan the output from left to right and use a stack to make sure the nesting is valid.
def validate_inline_marker_balance(candidate_html: str, inline_map: Dict[str, Dict[str, str]]) -> List[str]:
    errors = []

    token_pattern = r"⟦[A-Z0-9_]+⟧"
    tokens = re.findall(token_pattern, candidate_html)

    start_to_number = {}
    end_to_number = {}

    for marker_number, marker_info in inline_map.items():
        if marker_number.startswith("EMPTY_"):
            continue
        start_to_number[marker_info["start_marker"]] = marker_number
        end_to_number[marker_info["end_marker"]] = marker_number

    stack = []

    for token in tokens:
        if token in start_to_number:
            marker_number = start_to_number[token]
            stack.append(marker_number)
            continue

        if token in end_to_number:
            marker_number = end_to_number[token]

            if len(stack) == 0:
                errors.append("Found end marker " + token + " before any matching start marker.")
                continue

            last_open_number = stack[len(stack) - 1]

            if last_open_number != marker_number:
                errors.append("Marker nesting is not balanced around " + token + ".")
                continue

            stack.pop()

    if len(stack) > 0:
        errors.append("Some inline markers were opened but not closed correctly.")

    return errors


# This function restores editable inline markers and protected KEEP markers back to HTML.
def restore_all_markers(candidate_html: str, inline_map: Dict[str, Dict[str, str]], keep_map: Dict[str, Dict[str, str]]) -> str:
    restored_html = candidate_html

    # First restore protected KEEP markers.
    for marker_number, marker_info in keep_map.items():
        marker_text = marker_info["full_marker_text"]
        original_html = marker_info["original_html"]
        restored_html = restored_html.replace(marker_text, original_html)

    # Then restore empty markers such as <br/>.
    for marker_number, marker_info in inline_map.items():
        if marker_number.startswith("EMPTY_"):
            empty_marker = marker_info["empty_marker"]
            original_html = marker_info["original_html"]
            restored_html = restored_html.replace(empty_marker, original_html)

    # Finally restore paired inline start/end markers.
    for marker_number, marker_info in inline_map.items():
        if marker_number.startswith("EMPTY_"):
            continue

        start_marker = marker_info["start_marker"]
        end_marker = marker_info["end_marker"]
        opening_html = marker_info["opening_html"]
        closing_html = marker_info["closing_html"]

        restored_html = restored_html.replace(start_marker, opening_html)
        restored_html = restored_html.replace(end_marker, closing_html)

    return restored_html

# COMMAND ----------
# MAGIC %md
# MAGIC ## Validation
# MAGIC
# MAGIC After the model rewrites a block, we validate the result.
# MAGIC
# MAGIC The validator checks:
# MAGIC
# MAGIC - the result still parses as a single block
# MAGIC - the root tag is still the same
# MAGIC - root attributes are still the same
# MAGIC - descendant tag structure is still the same after marker restoration
# MAGIC - protected markers survived unchanged before restoration

# COMMAND ----------

# This function validates a rewritten block after all markers have already been restored.
def validate_restored_block(original_html: str, candidate_html: str) -> Dict[str, object]:
    result = {}
    result["is_valid"] = True
    result["errors"] = []

    try:
        original_tag = extract_single_tag(original_html)
    except Exception as exc:
        result["is_valid"] = False
        result["errors"].append("Original block could not be parsed: " + str(exc))
        return result

    try:
        candidate_tag = extract_single_tag(candidate_html)
    except Exception as exc:
        result["is_valid"] = False
        result["errors"].append("Candidate block could not be parsed: " + str(exc))
        return result

    if original_tag.name != candidate_tag.name:
        result["is_valid"] = False
        result["errors"].append(
            "Root tag changed from <" + original_tag.name + "> to <" + candidate_tag.name + ">."
        )

    if normalize_attrs(original_tag) != normalize_attrs(candidate_tag):
        result["is_valid"] = False
        result["errors"].append("Root tag attributes changed.")

    original_signature = structure_signature(original_tag)
    candidate_signature = structure_signature(candidate_tag)

    if original_signature != candidate_signature:
        result["is_valid"] = False
        result["errors"].append(
            "Tag structure changed. A tag moved, disappeared, or a new tag was introduced."
        )

    return result

