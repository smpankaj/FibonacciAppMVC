# This function transforms a full HTML fragment by rewriting each leaf block independently.
def transform_html_fragment(
    fragment: str,
    client: AzureOpenAI,
    deployment_name: str,
    rules: Sequence[str],
    max_attempts_per_block: int = 3,
    fail_on_validation_error: bool = True,
) -> Tuple[str, List[Dict[str, object]]]:
    soup, root = parse_fragment(fragment)
    targets = find_leaf_rewrite_targets(root)

    report = []
    block_index = 1

    for tag in targets:
        original_html = str(tag)
        block_tag_name = tag.name

        rewrite_result = rewrite_one_block(
            client=client,
            deployment_name=deployment_name,
            block_html=original_html,
            block_tag_name=block_tag_name,
            rules=rules,
            max_attempts=max_attempts_per_block,
        )

        report_item = {}
        report_item["index"] = block_index
        report_item["tag"] = block_tag_name
        report_item["strategy"] = rewrite_result["strategy"]
        report_item["attempts"] = rewrite_result["attempts"]
        report_item["is_valid"] = rewrite_result["is_valid"]
        report_item["errors"] = rewrite_result["errors"]
        report_item["original_html"] = rewrite_result["original_html"]
        report_item["prepared_html"] = rewrite_result["prepared_html"]
        report_item["rewritten_html"] = rewrite_result["rewritten_html"]
        report_item["restored_html"] = rewrite_result["restored_html"]

        report.append(report_item)

        if rewrite_result["is_valid"]:
            replacement_tag = extract_single_tag(rewrite_result["restored_html"])
            tag.replace_with(replacement_tag)
        else:
            if fail_on_validation_error:
                error_text = "; ".join(rewrite_result["errors"])
                raise ValueError(
                    "Validation failed for block "
                    + str(block_index)
                    + " <"
                    + block_tag_name
                    + ">: "
                    + error_text
                )

        block_index = block_index + 1

    final_html = fragment_to_string(root)
    return final_html, report

